# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
# uv.lock is COMMITTED on purpose: CI runs `uv sync` and must resolve the
# locked toolchain (an unpinned `ruff>=0.8` broke deploys when ruff 0.16.0
# shipped new-stable rules). Do not re-ignore it.

# Node
node_modules/

# Env
.env
.env.local
.env.*.local
.env.staging
.env.production

# Terraform
*.tfstate
*.tfstate.*
.terraform/
terraform.tfvars

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Local context & examples (not part of the service)
context/
examples/

# Dev logs
.dev-logs/
tfplan*

.vercel

# Build artifacts
apps/web/.next/
# Verification builds (`npm run build:local`) target their own dir so they cannot
# clobber a live `next dev` server's chunks — see apps/web/next.config.mjs.
apps/web/.next-verify/
packages/api-client/dist/
*.tsbuildinfo

# Playwright artifacts
apps/web/test-results/
apps/web/playwright-report/

.env*
# .env.example files are documentation, not secrets — keep them trackable
# (negation must follow the blanket .env* rule above; META-AUDIT P2)
!.env.example

# Claude Code personal overrides
.claude/settings.local.json
apps/email-listener/listener-*.log

# Remote Control session log — contains a live session/environment URL
.planning/night-run/remote-control.log
.planning/night-run/resume-log.txt

# GSD Core (open-gsd/gsd-core v1.8.0) — vendored into the repo so the /gsd:*
# commands, gsd-* agents and gsd-* skills persist across ephemeral remote
# sessions (there is no persistent user-scope plugin store here). The hook
# scripts live under .claude/gsd/ (tracked) but are NOT auto-wired — see
# .planning/GSD-INSTALL.md for the opt-in settings snippet and the reconciliation
# notes. Non-GSD agents/skills stay ignored, matching the original convention.
.claude/skills/*
!.claude/skills/polytoken-design-system/
!.claude/skills/gsd-*/
.claude/agents/*
!.claude/agents/gsd-*.md
.claude/gsd-support/
# Transient Workflow-tool isolated worktrees (created/removed per run)
.claude/worktrees/

# Windows-path junk from daemon tests running on Linux (pre-existing win32 tests)
apps/daemon/\\tmp\\daemon-tools-*

# UI review captures — contain signed-in app state (docs/RUN-LOCAL + CLAUDE.md say gitignored; the rule was missing)
.planning/ui-reviews/

# Planning build artifacts & runtime files (untracked 2026-07-22)
.planning/graphs/graph.json
.planning/graphs/.last-build-snapshot.json
.planning/night-run/HEARTBEAT
.planning/.pending-auth-captures.jsonl
