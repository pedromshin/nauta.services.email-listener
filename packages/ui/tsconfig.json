{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@polytoken/ui": ["./src/index.ts"],
      "@polytoken/ui/*": ["./src/*"]
    }
  },
  "include": ["src", "tailwind.config.ts"],
  "exclude": ["node_modules", "src/__tests__"]
}
