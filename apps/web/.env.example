# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Client-side Supabase auth (browser bundle). REQUIRED AT BUILD TIME — `next
# build` collects page data for auth-touching routes and throws if these are
# absent (they must be present in the Vercel project env, not just at runtime).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Email Listener service (server-side only — never NEXT_PUBLIC_) ────────────
# These vars are read only inside tRPC mutations (server-side); they never reach
# the client bundle and must NOT be prefixed with NEXT_PUBLIC_.
EMAIL_LISTENER_URL=http://localhost:8000
EMAIL_LISTENER_API_KEY=<your-email-listener-api-key>

# ── Forwarding seam (Phase 45 Plan 06, THRD-04 — server-side only) ────────────
# The web app builds each user's personal forwarding address as
# u-{token}@FORWARDING_EMAIL_DOMAIN (packages/api-client/src/router/forwarding).
# MUST equal the SES-verified inbound domain (aws_ses_domain_identity.main in
# infrastructure/aws/ses.tf — currently magnitudetech.com.br) AND the domain a
# catch-all SES receipt rule actually routes (see FORWARDING-RUNBOOK.md Section 1
# — that terraform change is user-gated and not yet applied). A mismatch here
# produces syntactically valid but unroutable addresses — mail silently bounces.
FORWARDING_EMAIL_DOMAIN=magnitudetech.com.br
