# Polytoken Email Listener — local development settings
# Copy to .env and adjust. All values also settable via real env vars.

ENVIRONMENT=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

LOG_LEVEL=DEBUG
LOG_JSON=false

# Empty API_KEY in development bypasses auth for local testing.
# Staging/production read this from AWS Secrets Manager (fails closed if empty).
API_KEY=
API_KEY_HEADER=X-API-Key
