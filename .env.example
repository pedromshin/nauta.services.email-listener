# ── Database (Drizzle / packages/db) ─────────────────────────────────
# Copy to .env.local for local dev (values below work with `npm run sb:start`).
# For staging/prod, copy to .env.staging / .env.production and fill in the
# database password from the Supabase dashboard (Settings → Database).

# local (Supabase Docker stack)
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
POSTGRES_URL_NON_POOLING=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# staging (polytoken-staging, ref fyfwkjvbcrmjqjysdyqw) — use in .env.staging
# POSTGRES_URL=postgresql://postgres.fyfwkjvbcrmjqjysdyqw:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
# POSTGRES_URL_NON_POOLING=postgresql://postgres.fyfwkjvbcrmjqjysdyqw:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# prod (polytoken-prod, ref dazyccjijdahxyciptkp) — use in .env.production
# POSTGRES_URL=postgresql://postgres.dazyccjijdahxyciptkp:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
# POSTGRES_URL_NON_POOLING=postgresql://postgres.dazyccjijdahxyciptkp:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# ── Web app (apps/web) — Supabase Storage ─────────────────────────────
# Used by GET /api/attachments/[id] to mint 60s signed download URLs.
# IMPORTANT: SUPABASE_SERVICE_ROLE_KEY is SERVER-SIDE ONLY — never prefix
# with NEXT_PUBLIC_ and never expose it in any response body.

# local (Supabase Docker stack — run `npm run sb:status` to read the service_role key)
SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=<paste output of `npm run sb:status` → SERVICE_ROLE_KEY>

# staging (polytoken-staging) — Supabase Dashboard → Project Settings → API
# SUPABASE_URL=https://fyfwkjvbcrmjqjysdyqw.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role secret from dashboard — server-side only>

# prod (polytoken-prod) — Supabase Dashboard → Project Settings → API
# SUPABASE_URL=https://dazyccjijdahxyciptkp.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role secret from dashboard — server-side only>
